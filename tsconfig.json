{
  "compilerOptions": {
    "strict": true,
    "target": "ES2025",
    "lib": ["ES2025"],
    "module":"ES2022",
    "moduleResolution": "Bundler",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "outDir": "dist",
    "sourceMap": true,
    "rootDir": "src",
    "types": ["node"]
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}
